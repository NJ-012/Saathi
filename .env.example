# Saathi environment variables — scaffold only, values pending implementation.

# Backend
PORT=4000
NODE_ENV=development


GROQ_API_KEY=
GROQ_MODEL=

# Classifier thresholds (green/yellow/red gate) — tune in next prompt
CONFIDENCE_THRESHOLD_GREEN=
CONFIDENCE_THRESHOLD_YELLOW=

# Channel adapter — defaults to the built-in webchat demo widget (served
# at /demo), so the live demo never depends on a WhatsApp number being
# approved in time. Set WHATSAPP_ENABLED=true (and fill in the vars below)
# once a real WhatsApp Cloud API number is approved and ready.
WHATSAPP_ENABLED=false
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Dashboard
VITE_API_BASE_URL=http://localhost:4000
